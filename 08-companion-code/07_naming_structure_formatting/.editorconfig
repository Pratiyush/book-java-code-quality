# EditorConfig (Chapter 6, Layer 3 baseline). Carries a few whitespace settings to every
# contributor's editor as they type — the author-time floor that runs before a formatter or a
# linter. It has no concept of line-wrapping or import order, so it complements a deterministic
# formatter; it does not replace one. `root = true` stops the upward search; closer files win.
# tag::editorconfig-baseline[]
root = true

[*.java]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
# end::editorconfig-baseline[]

[*.{xml,yml,yaml}]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
