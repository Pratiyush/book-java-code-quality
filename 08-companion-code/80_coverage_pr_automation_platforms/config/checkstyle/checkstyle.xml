<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!--
  The same small, curated house ruleset the other companion modules use (Chapter 16: curate a
  ruleset, don't enable everything and flood the build). High-signal checks only — naming, import
  hygiene, braces, a few coding/structure rules — and deliberately no finicky, high-noise checks
  (Indentation, MagicNumber, mandatory Javadoc on every member) so the gate stays credible. This
  module's own source and tests are held to it; the column limit (120) is this team's cited choice.
-->
<module name="Checker">
  <property name="severity" value="error"/>
  <property name="charset" value="UTF-8"/>
  <property name="fileExtensions" value="java"/>

  <!-- File-level (no AST needed) -->
  <module name="LineLength">
    <property name="max" value="120"/>
    <property name="ignorePattern" value="^(package|import) .*"/>
  </module>

  <module name="TreeWalker">
    <!-- Naming conventions (Chapter 6) -->
    <module name="PackageName"/>
    <module name="TypeName"/>
    <module name="MethodName"/>
    <module name="MemberName"/>
    <module name="ParameterName"/>
    <module name="LocalVariableName"/>
    <module name="ConstantName"/>
    <module name="StaticVariableName"/>
    <module name="LambdaParameterName"/>
    <module name="PatternVariableName"/>
    <module name="RecordComponentName"/>
    <module name="CatchParameterName"/>

    <!-- Import hygiene -->
    <module name="AvoidStarImport"/>
    <module name="RedundantImport"/>
    <module name="UnusedImports"/>

    <!-- Blocks and braces -->
    <module name="NeedBraces"/>
    <module name="LeftCurly"/>
    <module name="RightCurly"/>
    <module name="EmptyBlock">
      <property name="option" value="text"/>
    </module>

    <!-- Modifiers -->
    <module name="ModifierOrder"/>
    <module name="RedundantModifier"/>

    <!-- Coding / structure -->
    <module name="OneTopLevelClass"/>
    <module name="EqualsHashCode"/>
    <module name="SimplifyBooleanExpression"/>
    <module name="EmptyStatement"/>
    <module name="UpperEll"/>
    <module name="ArrayTypeStyle"/>
    <module name="OuterTypeFilename"/>
  </module>
</module>
