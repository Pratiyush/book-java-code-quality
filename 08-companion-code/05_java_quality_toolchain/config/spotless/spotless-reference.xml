<?xml version="1.0" encoding="UTF-8"?>
<!--
  Reference configuration (NOT wired into this module's live build) for the FORMATTER layer of the
  chapter's map — the author-time / pre-commit moment. It is shown rather than executed because the
  SOURCE-PIN identifier "Spotless 3.6.0" is the project / Gradle-plugin release line and does not
  resolve as a Maven-plugin coordinate (the spotless-maven-plugin is versioned on its own line); the
  Maven-plugin version literal is therefore left as a property to be set at pin time. This follows the
  Chapter 6 precedent exactly — see 09-flags/34_spotless_maven_plugin_version_unresolved.md. The
  module's green build does not depend on this file; the per-tool depth lives in Chapter 6.

  google-java-format is pinned to the SOURCE-PIN value (1.35.0, min JDK 21), which resolves. Pinning the
  formatter GAV is itself the point: a formatter's rendering can shift between its own versions, so it is
  pinned, not floated. ratchetFrom formats only files changed since trunk, so the formatter is adopted
  incrementally rather than in one repo-wide reformat.
-->
<plugin xmlns="http://maven.apache.org/POM/4.0.0">
  <!-- tag::formatter[] -->
  <groupId>com.diffplug.spotless</groupId>
  <artifactId>spotless-maven-plugin</artifactId>
  <version>${spotless.maven.plugin.version}</version> <!-- pin at /pin-source -->
  <configuration>
    <ratchetFrom>origin/main</ratchetFrom> <!-- format only files changed since trunk -->
    <java>
      <googleJavaFormat><version>1.35.0</version></googleJavaFormat>
    </java>
  </configuration>
  <!-- end::formatter[] -->
</plugin>
