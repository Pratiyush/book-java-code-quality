<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!--
  A small, high-signal house ruleset — the SOURCE-reading layer of this chapter's assembled toolchain.
  It is deliberately thin (naming, import hygiene, a line-length limit, braces) rather than "everything
  on": the map chapter's job is to show the LAYER, not to litigate a full style standard (that is
  Chapter 16). The column limit here is a cited team choice, not a universal truth — Checkstyle's own
  LineLength default is 80 and Google's bundled config sets 100 (Chapter 6, style-value neutrality). The
  per-tool depth — the full ruleset, suppression strategy, and tuning — lives in Chapter 16; this file
  exists so the chapter can show Checkstyle gating a real module green.
-->
<module name="Checker">
  <property name="severity" value="error"/>
  <property name="charset" value="UTF-8"/>
  <property name="fileExtensions" value="java"/>

  <!-- File-level line length (no AST needed); package/import lines are exempt per the documented default. -->
  <module name="LineLength">
    <property name="max" value="120"/>
    <property name="ignorePattern" value="^(package|import) .*"/>
  </module>

  <module name="TreeWalker">
    <!-- Naming conventions, each using its documented default format (UPPER_SNAKE constants, etc.). -->
    <module name="ConstantName"/>
    <module name="TypeName"/>
    <module name="MethodName"/>
    <module name="MemberName"/>
    <module name="LocalVariableName"/>
    <module name="ParameterName"/>
    <module name="RecordComponentName"/>

    <!-- Import hygiene: no star imports, no redundant or unused imports. -->
    <module name="AvoidStarImport"/>
    <module name="RedundantImport"/>
    <module name="UnusedImports"/>

    <!-- Blocks and braces. -->
    <module name="NeedBraces"/>
    <module name="LeftCurly"/>
    <module name="RightCurly"/>

    <!-- Modifiers and a few structural rules. -->
    <module name="ModifierOrder"/>
    <module name="RedundantModifier"/>
    <module name="OneTopLevelClass"/>
    <module name="EqualsHashCode"/>
    <module name="UpperEll"/>
    <module name="ArrayTypeStyle"/>
  </module>
</module>
